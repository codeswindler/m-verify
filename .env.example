# Shared
NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173,http://localhost:1420,tauri://localhost,http://tauri.localhost,https://tauri.localhost

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=m_verify
MYSQL_USER=m_verify
MYSQL_PASSWORD=m_verify_password
MYSQL_CONNECTION_LIMIT=10

# JWT/session security
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14
BCRYPT_ROUNDS=12
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-32-byte-random-secret

# Daraja C2B callback protection
DARAJA_CALLBACK_SECRET=change-me-callback-secret
DARAJA_IP_ALLOWLIST=

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_MAX=10
VERIFY_RATE_LIMIT_MAX=60

# Seed data
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_FULL_NAME=M-Verify Admin
SEED_ADMIN_RESET_PASSWORD=false
SEED_DEMO_DATA=true

# Frontend build-time config
VITE_API_BASE_URL=http://localhost:4000
VITE_DESKTOP_DOWNLOAD_URL=/downloads/M-Verify-Setup.exe

# Desktop update prompt
DESKTOP_LATEST_VERSION=0.1.4
DESKTOP_DOWNLOAD_URL=http://localhost:8080/downloads/M-Verify-Setup.exe
DESKTOP_UPDATER_URL=http://localhost:8080/downloads/M-Verify_0.1.4_x64-setup.exe
DESKTOP_UPDATER_SIGNATURE=
DESKTOP_UPDATER_PUB_DATE=
DESKTOP_RELEASE_NOTES=Download the latest M-Verify desktop installer.
DESKTOP_MANDATORY_UPDATE=false
