{
  "name": "@m-verify/mobile",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "typecheck": "tsc -b --noEmit",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "android:build": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 all",
    "android:debug": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 debug",
    "android:release": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 release",
    "android:bundle": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1 bundle"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@m-verify/shared": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
