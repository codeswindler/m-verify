# Public domains
API_DOMAIN=api.mverify.example.com
ADMIN_DOMAIN=admin.mverify.example.com
ACME_EMAIL=admin@example.com

# Shared
NODE_ENV=production
PUBLIC_API_BASE_URL=https://api.mverify.example.com
STK_PROMPT_TIMEOUT_MINUTES=2
VITE_API_BASE_URL=https://api.mverify.example.com
VITE_DESKTOP_DOWNLOAD_URL=/downloads/M-Verify-Setup.exe

# Desktop update prompt
DESKTOP_LATEST_VERSION=0.1.19
DESKTOP_DOWNLOAD_URL=https://admin.mverify.example.com/downloads/M-Verify-Setup.exe
DESKTOP_UPDATER_URL=https://admin.mverify.example.com/downloads/M-Verify_0.1.19_x64-setup.exe
DESKTOP_UPDATER_SIGNATURE=
DESKTOP_UPDATER_PUB_DATE=
DESKTOP_RELEASE_NOTES=PDF receipts with native WhatsApp file sharing.
DESKTOP_MANDATORY_UPDATE=false

# API
API_PORT=4000
TRUST_PROXY=true
CORS_ORIGINS=https://admin.mverify.example.com,tauri://localhost,http://tauri.localhost,https://tauri.localhost,capacitor://localhost,ionic://localhost,http://localhost,https://localhost

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=m_verify
MYSQL_USER=m_verify
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-root-password
MYSQL_CONNECTION_LIMIT=10

# JWT/session security
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14
BCRYPT_ROUNDS=12
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-32-byte-random-secret

# Daraja C2B callbacks
DARAJA_IP_ALLOWLIST=
DARAJA_OAUTH_SANDBOX_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
DARAJA_OAUTH_PRODUCTION_URL=https://api.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
DARAJA_C2B_REGISTER_SANDBOX_URL=https://sandbox.safaricom.co.ke/mpesa/c2b/v1/registerurl
DARAJA_C2B_REGISTER_PRODUCTION_URL=https://api.safaricom.co.ke/mpesa/c2b/v1/registerurl

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_MAX=10
VERIFY_RATE_LIMIT_MAX=60

# First platform admin seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-before-seeding
SEED_ADMIN_FULL_NAME=M-Verify Admin
SEED_ADMIN_RESET_PASSWORD=false
SEED_DEMO_DATA=false
